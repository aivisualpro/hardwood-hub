# ─────────────────────────────────────────────────────────────────────────────
# Hardwood Hub — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
# Public site URL — used to build absolute URLs (e.g. webhook callbacks)
NUXT_PUBLIC_SITE_URL=https://your-domain.com

# ── MongoDB ───────────────────────────────────────────────────────────────────
NUXT_MONGODB_URI=

# ── Session ───────────────────────────────────────────────────────────────────
# Minimum 64 random hex characters — used for HMAC-SHA256 session signing.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# The server refuses to start if this is missing or empty.
SESSION_SECRET=

# ── Google — Sign In + Gmail OAuth app ────────────────────────────────────────
# OAuth 2.0 credentials for the "Sign in with Google" button and Gmail integration.
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs must include: https://your-domain.com/api/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google — Calendar OAuth app ───────────────────────────────────────────────
# Intentionally a SEPARATE OAuth app from GOOGLE_CLIENT_ID above.
# Used exclusively for the Google Calendar integration (calendarFetch / watch channels).
# Authorized redirect URIs must include: https://your-domain.com/api/google-calendar/callback
GCAL_CLIENT_ID=
GCAL_CLIENT_SECRET=

# ── Google Cloud / Vertex AI ──────────────────────────────────────────────────
# Service account for Vertex AI (Gemini) and BigQuery access.
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ── Gemini API ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Server-side credentials — cloud name is returned to the client via the
# /api/upload/cloudinary-signature endpoint (not exposed as a public env var).
# Note: NEXT_PUBLIC_CLOUDINARY_* keys are NOT used — those are Next.js leftovers.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Vercel Blob Storage ───────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Browserless ───────────────────────────────────────────────────────────────
# Used for PDF generation via Puppeteer.
# Get a token at: https://www.browserless.io
BROWSERLESS_TOKEN=

# ── Gmail (SMTP app password) ─────────────────────────────────────────────────
# Used for transactional email (signed contract delivery, notifications).
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Gravity Forms ─────────────────────────────────────────────────────────────
GF_SITE_URL=https://your-wordpress-site.com
GF_CONSUMER_KEY=
GF_CONSUMER_SECRET=
GF_PUBLIC_API_KEY=
GF_PRIVATE_API_KEY=

# ── Calendly ──────────────────────────────────────────────────────────────────
CALENDLY_ACCESS_TOKEN=
CALENDLY_URL=https://calendly.com/your-link

# Webhook signing secrets — required for /api/crm/webhook to reject spoofed payloads.
# Calendly: Settings → Integrations → Webhooks → your webhook → Signing key
CALENDLY_WEBHOOK_SIGNING_KEY=
# Gravity Forms Webhooks add-on: configure a custom request header
# X-Gravity-Signature: sha1=<hmac> using this secret value.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GF_WEBHOOK_SECRET=

# ── CRM webhook + auto-sync ───────────────────────────────────────────────────
# Static token for the Gravity Forms Webhooks add-on (it can only send static
# headers). Set this, then in GF add a Request Header:
#   Name = X-Webhook-Token   Value = <this value>
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRM_WEBHOOK_TOKEN=
# Background auto-sync (pulls Gravity Forms + Calendly into MongoDB).
# Auto-enabled in dev. Set to true to enable on a long-running (non-serverless) server.
CRM_AUTOSYNC=
CRM_AUTOSYNC_MINUTES=5
# Protects GET /api/crm/cron-sync for external schedulers (e.g. Vercel Cron).
CRM_CRON_SECRET=
