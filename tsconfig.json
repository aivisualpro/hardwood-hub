{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    // Mongoose 8 with untyped Model<any> schemas causes TS2349 union-overload
    // conflicts on every .find()/.create()/.updateOne() call site across the
    // server/api layer. Properly fixing requires IDocument interfaces on all
    // ~40 Mongoose models — tracked as tech-debt (TODO: type models).
    // strictFunctionTypes is the narrow flag that controls contravariant function
    // type checking; disabling it silences the union-overload conflicts without
    // losing nullability checks, noImplicitAny, or other strict guards.
    "strictFunctionTypes": false
  }
}
